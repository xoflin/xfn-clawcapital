# Trading Parameters
CAPITAL=10000
WATCHLIST=BTC,ETH,SOL
MAX_RISK_PCT=1.0
STOP_LOSS_PCT=3.0
RISK_REWARD_RATIO=2.0
MIN_CONFIDENCE=0.60
MAX_POSITIONS=5
MAX_AV_TICKERS=2
